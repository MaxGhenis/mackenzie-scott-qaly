  # Floor on any sampled cost-per-QALY. A backstop against fat-tailed
  # reciprocals (QALYs = $/cpq grows large as cpq -> 0). In practice it almost
  # never binds: every cpq prior's 5th percentile is >= ~$25k.
  cost_per_qaly_floor_usd: 5000

# ---------------------------------------------------------------------------
# Shared conversion parameters
# ---------------------------------------------------------------------------
conversions:

  # Quality-adjusted life-years gained per premature death averted. Derived in
  # code as a discounted, quality-weighted annuity over remaining life years.
  # CALIBRATION ANCHORS (values are judgments calibrated to these sources, not
  # figures those papers report):
  qaly_per_death_averted:
    remaining_life_expectancy: {dist: normal, mean: 26, sd: 4, min: 5, unit: years}
    utility_weight: {dist: triangular, low: 0.60, mode: 0.78, high: 0.92, unit: utility_weight}
    source: >-
      Populations in the causal mortality studies are low-income adults roughly
      age 50-64. Remaining life expectancy ~26y is calibrated to
      [Chetty et al. (2016, JAMA)](https://jamanetwork.com/journals/jama/fullarticle/2513561):
      bottom-income-quartile life expectancy at 40 is ~78 (men) to ~83 (women),
      implying mid-20s remaining years around age 55. Utility ~0.78 is
      calibrated to US EQ-5D population norms (e.g.,
      [Jiang et al. 2021](https://link.springer.com/article/10.1007/s11136-020-02650-y),
      ages 55-64 ~0.80 overall, lower at low income). Discounted at 3% with a
      half-cycle correction.

  # HHS value per quality-adjusted life year (VQALY), used only to MONETIZE
  # the QALYs for a benefit/cost ratio. Not used to compute QALYs. This is the
  # correct series for QALY monetization — the prior revision applied the
  # per-life-YEAR value (VSLY) to quality-adjusted years, a convention this
  # replaces with HHS's published VQALY.
  vqaly_usd:
    dist: triangular
    low: 353000
    mode: 756000
    high: 1150000
    unit: usd_per_qaly
    dollars_base_year: 2026
    source: >-
      [HHS ASPE Standard Values for Regulatory Analysis 2026](https://aspe.hhs.gov/sites/default/files/documents/2d83af5823915d81871334ee08ad03d9/Standard-RIA-Values-2026.pdf),
      Table 3: VQALY for 2026 impacts at a 3% discount rate, low/central/high
      $339k / $726k / $1,105k in constant 2025 dollars. Inflated to the May
      2026 price level with [CPI-U](https://fred.stlouisfed.org/series/CPIAUCNS)
      335.123 / 321.943 (2025 annual average) = 1.0409: $353k / $756k / $1,150k.
      One series, one price level, denominated at the 3% reference rate; at
      other rates the model rescales by the adult PV-QALY ratio (vqaly_adult
      below), which reproduces HHS Table 2's discounted PV QALYs (19.5 at 3%,
      11.7 at 7%) to within 0.1%, keeping the benefit/cost ratio consistent
      with the discount slider.

  # Fixed inputs for the VQALY discount-rate rescaling. These are CALIBRATION
  # CONSTANTS chosen so a flat quality-weighted annuity reproduces HHS Table
  # 2's discounted PV QALYs (19.5 @3%, 11.7 @7%) to within 0.1% — they are not
  # demographic claims. (HHS's own age-40 inputs, 40.7 remaining years and
  # 33.6 undiscounted QALYs, embed survival curves and age-varying quality
  # weights that a flat annuity cannot represent with the same numbers; using
  # them directly misses the 7% endpoint by ~2.4%.)
  vqaly_adult:
    remaining_life_years: {dist: fixed, value: 37.7, unit: years}
    utility_weight: {dist: fixed, value: 0.8584, unit: utility_weight}

  # Global-health frontier, expressed as a QALY-equivalent cost with the
  # conversion arithmetic explicit (GiveWell reports lives saved, not QALYs).
  # Denominated at the 3% reference discount rate; when the model runs at a
  # different rate, it rescales this cost by the ratio of the child QALE at 3%
  # to the child QALE at that rate (frontier_child below), keeping the
  # frontier comparison like-for-like at any discount setting.
  frontier_cost_per_qaly_usd:
    dist: loguniform
    low: 150
    high: 260
    unit: usd_per_qaly
    dollars_base_year: 2026
    source: >-
      Derived from [GiveWell's current impact estimates](https://www.givewell.org/impact-estimates)
      of cost per life saved, 2022-2024 program averages: ~$4,000 (Malaria
      Consortium seasonal chemoprevention) to ~$5,500 (AMF nets), figures
      GiveWell rounds up to the nearest $500. Treating those as ~2023 dollars
      and inflating by [CPI-U](https://fred.stlouisfed.org/series/CPIAUCNS)
      335.123/304.702 = 1.10 gives ~$4,400-$6,050 per life. A child death
      averted at ~age 1 with ~65 remaining life-years, discounted at 3% with
      half-cycle correction (annuity ~28.9) and utility ~0.87, is ~25.1
      discounted QALYs, giving endpoints of ~$175-$241 per QALY-equivalent;
      the loguniform {150, 260} widens that for conversion uncertainty
      (utility, remaining years, price level). An earlier revision also used a
      2015 AMF figure ($3,340/life, itself already a discounted-QALY-era
      calculation, in ~2015 dollars); it is retired here in favor of
      GiveWell's current program averages.

  # Fixed conversion inputs for the frontier's life -> QALY arithmetic and its
  # discount-rate rescaling. Author calibration: ~65 remaining years for an
  # under-5 death averted in AMF/Malaria Consortium countries; utility ~0.87
  # near global population norms.
  frontier_child:
    remaining_life_years: {dist: fixed, value: 65, unit: years}
    utility_weight: {dist: fixed, value: 0.87, unit: utility_weight}

# ---------------------------------------------------------------------------
# TWO ORTHOGONAL ADJUSTMENTS (GiveWell-style), kept deliberately separate:
#
#   causal_credibility (per archetype, below) — IS THE MEASURED EFFECT REAL?
#     Internal validity only: how well the study design identifies causation.
#   realization_factor (global, here) — DOES SCOTT'S DOLLAR DELIVER IT?
#     Everything between a real effect and her marginal grant: external
#     validity/transport to her grantees, overhead leakage, counterfactual
#     funging — net of the capacity benefits of large unrestricted gifts.
#
# Division of labor: transportability concerns live HERE, not in credibility;
# cost-per-QALY priors are conditional on the effect being real and delivered.
# Each doubt enters exactly one layer.
#
# LIMITATIONS (disclosed, not hidden): credibility is drawn independently per
# archetype, while realization is one global draw — two opposite correlation
# extremes. A tier-correlated credibility variant widens the 90% interval ~7%
# and leaves the median unchanged. Credibility is also strictly positive, so
# the model puts no mass on zero or harmful effects; for assumption-tier
# buckets the mean of 0.07 approximates, but never reaches, a null.
# ---------------------------------------------------------------------------
realization_factor:
  dist: triangular
  low: 0.55
  mode: 0.80
  high: 1.10
  unit: multiplier
  source: >-
    AI-PROPOSED, AUTHOR-REVIEWED PRIOR (no literature estimate exists for this quantity).
    Downweight for transport/overhead/funging; upweight allowed past 1.0
    because [Center for Effective Philanthropy (2023)](https://cep.org/wp-content/uploads/2023/11/BigGiftsStudy_Report_Y2_FNL.pdf)
    finds large unrestricted gifts materially expand recipient capacity/reach.
    Stress-test with the interactive's realization slider (it moves the MODE of
    this triangle within [0.55, 1.10]).

# Evidence tiers by causal-identification design. AI-PROPOSED, AUTHOR-REVIEWED
# PRIORS (Claude drafted the levels):
# `mean` is the central credibility weight (1 = take the estimate at face
# value; 0 = shrink fully to the null of no health effect); `concentration`
# sets the spread (lower = more uncertain). Weaker designs get a lower mean
# AND a wider distribution. No published calibration of design -> credibility
# exists; the ordering is the defensible part, the levels are judgment.
evidence_tiers:
  randomized:     {mean: 0.85, concentration: 22, design: "RCT / clean natural randomization (e.g., lottery)"}
  strong_quasi:   {mean: 0.65, concentration: 13, design: "Credible quasi-experiment (DD/IV) with admin data and checks"}
  moderate_quasi: {mean: 0.45, concentration: 8,  design: "Quasi-experiment with notable concerns or a contested literature"}
  observational:  {mean: 0.22, concentration: 6,  design: "Associational; confounding-prone"}
  projection:     {mean: 0.15, concentration: 6,  design: "Model/IAM projection; no direct causal estimate for this lever"}
  assumption:     {mean: 0.07, concentration: 9,  design: "No causal health evidence; skeptical expert prior"}

# ---------------------------------------------------------------------------
# Dirichlet concentration governing uncertainty in the dollar allocation
# across archetypes. AI-proposed, author-reviewed (higher = shares held closer
# to central):
# the share centers below are data-derived, but the undisclosed third of
# dollars enters via a revenue-scaled imputation and the area->archetype
# mapping embeds judgment.
# ---------------------------------------------------------------------------
allocation_concentration: 60

