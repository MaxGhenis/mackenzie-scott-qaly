    36	def load_params(path: str | Path | None = None) -> dict:
    37	    """Load and validate the parameter file. Validation enforces typed units
    38	    and base-year dollar vintages on every sampled spec (see validate.py).
    39	
    40	    Derives ``meta.total_giving_usd`` (base-year dollars) from the nominal
    41	    ``meta.giving_tranches``: each tranche is inflated by cpi_target / cpi, so
    42	    the model's dollars and its cost-per-QALY inputs share one price level.
    43	    """
    44	    path = Path(path) if path else DEFAULT_PARAMS
    45	    with open(path) as fh:
    46	        params = validate_params(yaml.safe_load(fh))
    47	    meta = params["meta"]
    48	    target = float(meta["cpi_target"])
    49	    meta["total_giving_usd"] = sum(
    50	        float(t["nominal_usd"]) * target / float(t["cpi"]) for t in meta["giving_tranches"]
    51	    )
    52	    meta["total_giving_nominal_usd"] = sum(
    53	        float(t["nominal_usd"]) for t in meta["giving_tranches"]
    54	    )
    55	    return params
