    59	def nonus_fraction(locations: list | None) -> float:
    60	    """Share of an org's reported service locations outside the US."""
    61	    if not locations:
    62	        return 0.0
    63	    nonus = [
    64	        loc for loc in locations
    65	        if not loc.startswith("us") and loc != "north_america"
