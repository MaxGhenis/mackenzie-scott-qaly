   122	labels = {a: P["archetypes"][a]["label"] for a in P["archetypes"]}
   123	label_to_key = {v: k for k, v in labels.items()}
   124	giving_usd = S["total_giving_usd"]
   125	rows = []
   126	for lab, q in sorted(per.items(), key=lambda kv: -kv[1]):
   127	    key = label_to_key[lab]
   128	    share = V11["allocation_share"][key]
   129	    d = share * giving_usd
   130	    rows.append({
   131	        "Cause": lab,
   132	        "Dollars": usd(d),
   133	        "% of $": f"{100*share:.0f}%",
   134	        "QALYs": f"{q:,.0f}",
   135	        "% of QALYs": f"{100*q/mean_total:.0f}%" if q/mean_total >= 0.005 else "<1%",
