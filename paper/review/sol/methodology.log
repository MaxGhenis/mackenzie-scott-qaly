    58	def discounted_qale(years: np.ndarray, utility: np.ndarray, rate: float) -> np.ndarray:
    59	    """Present value of `utility` QALYs per year over `years` years, discounted
    60	    at `rate`, with the standard health-economics half-cycle correction: a death
    61	    averted "now" begins accruing life-years immediately, so the ordinary
    62	    (end-of-year) annuity is shifted by half a year via the ``(1+r)**0.5`` factor.
    63	
    64	        u * (1 - (1+r)^-L) / r * (1+r)^0.5
    65	    """
    66	    years = np.maximum(years, 0.0)
    67	    if rate <= 0:
    68	        return utility * years
    69	    annuity = (1.0 - (1.0 + rate) ** (-years)) / rate
    70	    return utility * annuity * (1.0 + rate) ** 0.5
