   125	def calibrate_elasticity(orgs: list, revenue: dict) -> tuple[float, float, int]:
   126	    """OLS of log10(gift amount) on log10(pre-gift revenue) over disclosed
   127	    pairs. Returns (elasticity beta, R^2, n)."""
   128	    xs, ys = [], []
   129	    for org in orgs:
   130	        rev = revenue.get(org["name"])
   131	        for gift in org.get("gifts") or []:
   132	            amount = gift.get("amount") or 0
   133	            if amount <= 0:
   134	                continue
   135	            r = pre_gift_revenue(rev, int(gift["year"]))
   136	            if r:
   137	                xs.append(np.log10(r))
   138	                ys.append(np.log10(amount))
   139	    x, y = np.array(xs), np.array(ys)
   140	    beta, intercept = np.polyfit(x, y, 1)
   141	    resid = y - (beta * x + intercept)
   142	    r2 = 1 - resid.var() / y.var()
   143	    return float(beta), float(r2), len(xs)
