   163	        {
   164	            "key": k,
   165	            "label": labels[k],
   166	            "usd": round(v),
   167	            "unspecified": k in _UNSPECIFIED,
   168	        }
   169	        for k, v in buckets.most_common()
   170	    ]
   171	    return {
   172	        "method": (
   173	            "All ledger dollars (disclosed + imputed) split equally across "
   174	            "each organization's reported service locations. 'Global' slices "
   175	            "of the top-50 audited organizations are redistributed per their "
   176	            "own published geographies (geo_audit.jsonl); unattributable "
   177	            "shares stay Global. Muted buckets name a reporting granularity, "
   178	            "not a place."
   179	        ),
   180	        "n_audited_orgs": n_audited,
   181	        "total_usd": round(sum(buckets.values())),
   182	        "regions": entries,
   183	    }
   184	
   185	
   186	def _org_region_dists(org, audit_shares):
   187	    """(us_dist, abroad_dist, all_dist): region-bucket dollar distributions
   188	    for one org's US-side, abroad-side, and overall geography."""
   189	    locs = org.get("locations") or []
   190	    if audit_shares:
   191	        us = {"us_national": 1.0}
   192	        abroad = {}
   193	        for rk, sh in audit_shares.items():
   194	            if rk == "north_america_us":
   195	                continue
   196	            abroad[_AUDIT_REGION[rk]] = abroad.get(_AUDIT_REGION[rk], 0.0) + sh
   197	        tot = sum(abroad.values())
   198	        abroad = {k: v / tot for k, v in abroad.items()} if tot else {"global": 1.0}
   199	        us_w = audit_shares.get("north_america_us", 0.0)
   200	        alls = {k: v * (1 - us_w) for k, v in abroad.items()}
   201	        if us_w:
   202	            alls["us_national"] = alls.get("us_national", 0.0) + us_w
   203	        return us, abroad, alls
   204	    if not locs:
   205	        d = {"us_national": 1.0}
   206	        return d, {"global": 1.0}, d
   207	    us_locs = [l for l in locs if _is_us(l)]
   208	    ab_locs = [l for l in locs if not _is_us(l)]
   209	    def dist(ls):
   210	        out: dict[str, float] = {}
   211	        for l in ls:
   212	            b = _bucket(l)
   213	            out[b] = out.get(b, 0.0) + 1.0 / len(ls)
   214	        return out
   215	    us = dist(us_locs) if us_locs else {"us_national": 1.0}
   216	    abroad = dist(ab_locs) if ab_locs else {"global": 1.0}
   217	    return us, abroad, dist(locs)
   218	
   219	
   220	def archetype_region_matrix(data_dir=None) -> dict:
   221	    """Per-archetype regional dollar shares, mirroring the allocation
   222	    pipeline's crediting rules exactly (substantive areas, PASSTHROUGH,
   223	    SPLIT_HEALTH halves, audited geo routing). Within each archetype the
   224	    model prices all regions identically, so these shares also decompose
   225	    the archetype's QALYs — by construction, not as an empirical claim."""
   226	    from .allocation import (GEO_SPLIT_TARGETS, GLOBAL_HEALTH, PASSTHROUGH,
   227	                             SPLIT_HEALTH, SPLIT_HEALTH_TARGETS,
   228	                             derive_shares, load_geo_overlay, nonus_fraction)
   229	
   230	    orgs, leaves, mapping = load_inputs(data_dir)
   231	    overlay = load_geo_overlay(data_dir)
   232	    audit = load_geo_audit(data_dir)
   233	    # geo_audit region shares are keyed by audit vocabulary; keep raw rows too
   234	    import json as _json
   235	    from .allocation import DATA_DIR
   236	    d = Path(data_dir) if data_dir else DATA_DIR
   237	    raw_audit = {}
   238	    for line in (d / "geo_audit" / "geo_audit.jsonl").read_text().splitlines():
   239	        row = _json.loads(line)
   240	        raw_audit[row["name"]] = row.get("region_shares") or {}
   241	    _, stats = derive_shares(data_dir)
   242	    org_usd = stats["org_usd"]
   243	
   244	    matrix: dict[str, Counter] = {}
   245	
   246	    def add(target: str, dist: dict[str, float], amount: float) -> None:
   247	        if amount <= 0:
   248	            return
   249	        m = matrix.setdefault(target, Counter())
   250	        for region, w in dist.items():
   251	            m[region] += amount * w
   252	
   253	    for org, usd in zip(orgs, org_usd, strict=True):
   254	        if not usd:
   255	            continue
   256	        labels = [leaves[c]["label"] for c in org.get("giftAreas") or []]
   257	        subst = [la for la in labels if mapping[la] != PASSTHROUGH] or labels
   258	        if not subst:
   259	            continue
   260	        weight = usd / len(subst)
   261	        geo = overlay.get(org["name"], nonus_fraction(org.get("locations")))
   262	        us_d, ab_d, all_d = _org_region_dists(org, raw_audit.get(org["name"]))
   263	        for la in subst:
   264	            target = mapping[la]
   265	            if target == PASSTHROUGH:
   266	                continue
   267	            local = weight
   268	            if target in GEO_SPLIT_TARGETS and geo > 0:
   269	                add(GLOBAL_HEALTH, ab_d, weight * geo)
   270	                local = weight * (1 - geo)
   271	            if target == SPLIT_HEALTH:
   272	                for half in SPLIT_HEALTH_TARGETS:
   273	                    add(half, us_d if target in GEO_SPLIT_TARGETS else all_d, local / 2)
   274	            elif target in GEO_SPLIT_TARGETS:
   275	                add(target, us_d, local)
   276	            else:
   277	                add(target, all_d, local)
   278	
   279	    labels = dict(_LABELS)
   280	    labels.update({k: v for k, v in _US_BUCKETS})
   281	    out_regions = sorted({r for m in matrix.values() for r in m})
   282	    return {
   283	        "note": (
   284	            "Within each archetype the model prices all delivery locations "
   285	            "identically (the health->global_health routing is the only "
   286	            "geographic pricing), so these dollar shares decompose the "
   287	            "archetype's QALYs by construction."
   288	        ),
   289	        "regions": [
   290	            {"key": k, "label": labels[k], "unspecified": k in _UNSPECIFIED}
   291	            for k in out_regions
   292	        ],
   293	        "matrix": {
   294	            t: {k: round(v / sum(m.values()), 6) for k, v in m.items()}
   295	            for t, m in matrix.items()
   296	        },
   297	    }
   298	
   299	
   300	def aggregate(orgs: list) -> dict:
   301	    """Return {us_usd, nonus_usd, regions: [{key, label, usd}]} over
   302	    disclosed dollars, equal-split across each org's listed locations."""
   303	    us = 0.0
   304	    regions: Counter[str] = Counter()
   305	    for o in orgs:
   306	        usd = sum(g.get("amount") or 0 for g in o.get("gifts", []))
   307	        locs = o.get("locations") or []
   308	        if not usd or not locs:
   309	            continue
   310	        per = usd / len(locs)
   311	        for loc in locs:
   312	            if _is_us(loc):
   313	                us += per
   314	            else:
   315	                key = loc if loc in _LABELS else _CODE_REGION.get(loc, "other")
   316	                regions[key] += per
   317	    entries = [
   318	        {"key": k, "label": _LABELS[k], "usd": round(v)}
   319	        for k, v in regions.most_common()
   320	    ]
   321	    return {
   322	        "source": "data/yieldgiving/organisations.json (snapshot 2026-07-11)",
   323	        "method": (
   324	            "Disclosed gift dollars split equally across each organization's "
   325	            "reported service locations; ISO country codes rolled into the "
   326	            "database's region vocabulary. Descriptive data, not a model "
   327	            "output."
   328	        ),
   329	        "us_usd": round(us),
   330	        "nonus_usd": round(sum(regions.values())),
   331	        "regions": entries,
   332	    }
   333	
   334	
   335	def main() -> None:
   336	    from .allocation import derive_shares
   337	
   338	    orgs, _, _ = load_inputs()
   339	    _, stats = derive_shares()
   340	    out = {
   341	        "disclosed_nonus": aggregate(orgs),
   342	        "full_ledger": aggregate_full(orgs, stats["org_usd"], load_geo_audit()),
   343	        "archetype_region_matrix": archetype_region_matrix(),
   344	    }
   345	    path = Path(__file__).resolve().parents[2] / "web" / "geo.json"
   346	    path.write_text(json.dumps(out, indent=1) + "\n")
   347	    fl = out["full_ledger"]
   348	    print(f"wrote {path}: full ledger ${fl['total_usd']/1e9:.2f}B "
   349	          f"in {len(fl['regions'])} buckets")
   350	
   351	
   352	if __name__ == "__main__":
   353	    main()

