   172	
   173	    unmapped = sorted({leaf["label"] for leaf in leaves.values()} - set(mapping))
   174	    if unmapped:
   175	        raise ValueError(f"focus areas missing from leaf_to_archetype.yaml: {unmapped}")
   176	
   177	    def substantive_areas(org: dict) -> list[str]:
   178	        labels = [leaves[code]["label"] for code in org.get("giftAreas") or []]
   179	        return [la for la in labels if mapping[la] != PASSTHROUGH] or labels
   180	
   181	    def credit(usd: dict, org: dict, amount: float) -> None:
   182	        areas = substantive_areas(org)
   183	        weight = amount / len(areas)
   184	        geo = overlay.get(org["name"], nonus_fraction(org.get("locations")))
   185	        for label in areas:
   186	            target = mapping[label]
   187	            if target == PASSTHROUGH:
   188	                continue  # vehicle-only org: spread via normalization
   189	            local = weight
   190	            if target in GEO_SPLIT_TARGETS and geo > 0:
   191	                usd[GLOBAL_HEALTH] += weight * geo
   192	                local = weight * (1 - geo)
   193	            if target == SPLIT_HEALTH:
   194	                for half in SPLIT_HEALTH_TARGETS:
   195	                    usd[half] += local / 2
   196	            else:
   197	                usd[target] += local
   198	
   199	    usd: dict[str, float] = defaultdict(float)
