   220	        "n_orgs": len(orgs),
   221	        "n_gifts": n_gifts,
   222	        "n_disclosed": n_disclosed,
   223	        "disclosed_usd": disclosed_usd,
   224	    }
   225	
   226	    if impute:
   227	        revenue = load_revenue(data_dir)
   228	        beta, r2, n_cal = calibrate_elasticity(orgs, revenue)
   229	        params = yaml.safe_load(Path(params_path or PARAMS_PATH).read_text())
   230	        window_total: dict[tuple, float] = defaultdict(float)
   231	        for tranche in params["meta"]["giving_tranches"]:
   232	            window_total[year_window(int(tranche["year"]))] += float(tranche["nominal_usd"])
