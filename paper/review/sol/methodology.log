   131	    # 1. QALYs per premature death averted (shared across mortality-based archetypes)
   132	    qd = params["conversions"]["qaly_per_death_averted"]
   133	    L = sample(qd["remaining_life_expectancy"], n, rng)
   134	    u = np.clip(sample(qd["utility_weight"], n, rng), 0.01, 1.0)
   135	    qaly_per_death = discounted_qale(L, u, rate)
   136	
   137	    # 2. Global realization factor
   138	    realization = np.clip(sample(params["realization_factor"], n, rng), 0.0, None)
   139	
   140	    # 3. Dirichlet allocation centered on the parameter-file shares
   141	    arche = params["archetypes"]
   142	    labels = [a["label"] for a in arche.values()]
   143	    central = np.array([a["allocation_share"] for a in arche.values()], dtype=float)
   144	    central = central / central.sum()
   145	    conc = float(params.get("allocation_concentration", 50))
   146	    shares = rng.dirichlet(central * conc, size=n)        # (n, k)
   147	
   148	    # 4-5. Per-archetype cost-per-QALY, causal credibility, and QALYs
   149	    tiers = params.get("evidence_tiers", {})
   150	    per_archetype: dict = {}
   151	    cost_per_qaly: dict = {}
   152	    credibility: dict = {}
   153	    total = np.zeros(n)
   154	    for j, (key, a) in enumerate(arche.items()):
   155	        method = a.get("method", "cost_per_qaly")
   156	        if method == "cost_per_qaly":
   157	            cpq = sample(a["cost_per_qaly_usd"], n, rng)
   158	        elif method == "cost_per_life":
   159	            cpl = sample(a["cost_per_life_usd"], n, rng)
   160	            cpq = cpl / qaly_per_death
   161	        elif method == "cost_per_life_year":
   162	            # $/life-year -> $/QALY via the same utility-weight draw used in
   163	            # the QALE annuity (a life-year in this population is ~u QALYs).
   164	            cply = sample(a["cost_per_life_year_usd"], n, rng)
   165	            cpq = cply / u
   166	        else:
   167	            raise ValueError(f"Unknown method {method!r} for archetype {key!r}")
