   125	def run(params: dict, n: int = 100_000, seed: int = 0) -> Results:
   126	    rng = np.random.default_rng(seed)
   127	    giving = float(params["meta"]["total_giving_usd"])
   128	    rate = float(params["meta"]["discount_rate"])
   129	    cpq_floor = float(params["meta"].get("cost_per_qaly_floor_usd", 5000.0))
