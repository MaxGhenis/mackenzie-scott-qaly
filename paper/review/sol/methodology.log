     1	"""Sampling helpers that turn a parameter spec (a dict from parameters.yaml)
     2	into a vector of Monte Carlo draws.
     3	
     4	A spec is one of:
     5	
     6	    {"dist": "fixed",        "value": x}
     7	    {"dist": "uniform",      "low": a, "high": b}
     8	    {"dist": "loguniform",   "low": a, "high": b}          # a, b > 0
     9	    {"dist": "triangular",   "low": a, "mode": m, "high": b}
    10	    {"dist": "normal",       "mean": m, "sd": s, "min": lo?, "max": hi?}
    11	    {"dist": "lognormal_ci", "low": p05, "high": p95}      # 5th/95th pct, > 0
    12	
    13	A bare int/float is treated as a fixed value, so scalars can be written plainly.
    14	"""
    15	from __future__ import annotations
    16	
    17	import numpy as np
    18	
    19	# 90% of a normal lies within +/- 1.6448536 sd of the mean.
    20	_Z95 = 1.6448536269514722
    21	
    22	
    23	def sample(spec, n: int, rng: np.random.Generator) -> np.ndarray:
    24	    """Draw `n` samples for a single parameter `spec`."""
    25	    if isinstance(spec, (int, float)):
    26	        return np.full(n, float(spec))
    27	    if not isinstance(spec, dict) or "dist" not in spec:
    28	        raise ValueError(f"Bad parameter spec: {spec!r}")
    29	
    30	    kind = spec["dist"]
    31	
    32	    if kind == "fixed":
    33	        return np.full(n, float(spec["value"]))
    34	
    35	    if kind == "uniform":
    36	        return rng.uniform(spec["low"], spec["high"], n)
    37	
    38	    if kind == "loguniform":
    39	        lo, hi = float(spec["low"]), float(spec["high"])
    40	        if lo <= 0 or hi <= 0:
    41	            raise ValueError("loguniform bounds must be positive")
    42	        return np.exp(rng.uniform(np.log(lo), np.log(hi), n))
    43	
    44	    if kind == "triangular":
    45	        return rng.triangular(spec["low"], spec["mode"], spec["high"], n)
    46	
    47	    if kind == "normal":
    48	        draws = rng.normal(spec["mean"], spec["sd"], n)
    49	        if "min" in spec or "max" in spec:
    50	            draws = np.clip(draws, spec.get("min", -np.inf), spec.get("max", np.inf))
    51	        return draws
    52	
    53	    if kind == "beta":
    54	        # Parameterized by mean in (0,1) and concentration k = a + b.
    55	        # Higher k = tighter. Used for causal-credibility ratings.
    56	        mean, k = float(spec["mean"]), float(spec["concentration"])
    57	        if not 0 < mean < 1 or k <= 0:
    58	            raise ValueError("beta needs 0 < mean < 1 and concentration > 0")
    59	        return rng.beta(mean * k, (1.0 - mean) * k, n)
    60	
    61	    if kind == "lognormal_ci":
    62	        # Interpret {low, high} as the 5th and 95th percentiles of a lognormal.
    63	        lo, hi = float(spec["low"]), float(spec["high"])
    64	        if lo <= 0 or hi <= 0 or hi <= lo:
    65	            raise ValueError("lognormal_ci needs 0 < low < high")
    66	        mu = (np.log(lo) + np.log(hi)) / 2.0
    67	        sigma = (np.log(hi) - np.log(lo)) / (2.0 * _Z95)
    68	        return np.exp(rng.normal(mu, sigma, n))
    69	
    70	    raise ValueError(f"Unknown distribution: {kind!r}")
    71	
    72	
    73	def implied_median(spec) -> float:
    74	    """Best-guess central value of a spec, for quick non-MC reporting."""
    75	    if isinstance(spec, (int, float)):
    76	        return float(spec)
    77	    kind = spec["dist"]
    78	    if kind == "fixed":
    79	        return float(spec["value"])
    80	    if kind == "uniform":
    81	        return (spec["low"] + spec["high"]) / 2.0
    82	    if kind == "loguniform":
    83	        return float(np.sqrt(spec["low"] * spec["high"]))
    84	    if kind == "triangular":
    85	        return float(spec["mode"])
    86	    if kind == "normal":
    87	        return float(spec["mean"])
    88	    if kind == "lognormal_ci":
    89	        return float(np.sqrt(spec["low"] * spec["high"]))
    90	    if kind == "beta":
    91	        return float(spec["mean"])
    92	    raise ValueError(f"Unknown distribution: {kind!r}")

