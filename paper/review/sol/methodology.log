   146	def load_geo_overlay(data_dir: str | Path | None = None) -> dict[str, float]:
   147	    """Audited non-US fractions for 'global'-listed orgs (geo_audit.jsonl):
   148	    org name -> (1 - audited US share). Produced by the terra research sweep;
   149	    each row carries source_url + confidence. Opt-in via derive_shares."""
   150	    d = Path(data_dir) if data_dir else DATA_DIR
   151	    path = d / "geo_audit" / "geo_audit.jsonl"
   152	    out: dict[str, float] = {}
