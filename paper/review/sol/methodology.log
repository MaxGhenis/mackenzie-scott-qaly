   202	    disclosed_by_window: dict[tuple, float] = defaultdict(float)
   203	    org_usd = [0.0] * len(orgs)  # dollars credited per org (index-aligned)
   204	    undisclosed: list[tuple[int, dict, int]] = []  # (org index, org, gift year)
   205	    for i, org in enumerate(orgs):
   206	        for gift in org.get("gifts") or []:
   207	            n_gifts += 1
   208	            year = int(gift["year"])
   209	            amount = gift.get("amount") or 0
   210	            if amount > 0:
   211	                n_disclosed += 1
   212	                disclosed_usd += amount
   213	                disclosed_by_window[year_window(year)] += amount
   214	                org_usd[i] += amount
   215	                credit(usd, org, amount)
   216	            else:
   217	                undisclosed.append((i, org, year))
