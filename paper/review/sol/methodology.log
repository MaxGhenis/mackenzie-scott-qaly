   238	
   239	def _midranks(x: np.ndarray) -> np.ndarray:
   240	    """Ranks with ties assigned their group average (midranks), so tied values
   241	    contribute zero spurious correlation instead of argsort-order noise."""
   242	    order = np.argsort(x, kind="stable")
   243	    ranks = np.empty(len(x))
   244	    ranks[order] = np.arange(len(x), dtype=float)
   245	    _, inverse, counts = np.unique(x, return_inverse=True, return_counts=True)
   246	    sums = np.bincount(inverse, weights=ranks)
   247	    return sums[inverse] / counts[inverse]
   248	
   249	
   250	def _spearman(x: np.ndarray, y: np.ndarray) -> float:
   251	    """Spearman rank correlation with average ranks for ties (no scipy)."""
   252	    rx = _midranks(np.asarray(x, dtype=float))
   253	    ry = _midranks(np.asarray(y, dtype=float))
   254	    rx -= rx.mean()
   255	    ry -= ry.mean()
   256	    denom = np.sqrt((rx @ rx) * (ry @ ry))
   257	    return float(rx @ ry / denom) if denom else 0.0
   258	
   259	
   260	def driver_sensitivity(res: Results) -> list[tuple[str, float]]:
   261	    """Rank inputs by |Spearman correlation| with total QALYs -- a probabilistic
   262	    (one-way) sensitivity analysis identifying what drives the spread."""
   263	    total = res.total_qalys
   264	    rows: list[tuple[str, float]] = [
   265	        ("Realization factor (global)", _spearman(res.realization, total)),
   266	        ("QALYs per death averted", _spearman(res.qaly_per_death, total)),
   267	    ]
   268	    for j, label in enumerate(res.share_labels):
   269	        rows.append((f"$/QALY · {label}", _spearman(res.cost_per_qaly[label], total)))
   270	        rows.append((f"Credibility · {label}", _spearman(res.credibility[label], total)))
   271	        rows.append((f"Allocation · {label}", _spearman(res.shares[:, j], total)))
   272	    rows.sort(key=lambda t: abs(t[1]), reverse=True)
   273	    return rows
     1	"""Derive the dollar-allocation centers from Yield Giving's gift database.
     2	
     3	Scott's Yield Giving site publishes a gift-level database
     4	(https://yieldgiving.com/gifts, snapshot in ``data/yieldgiving/``): every
     5	organization with its org-reported focus areas, and a dollar amount for about
     6	two-thirds of the disclosed dollars (``amount: 0`` marks undisclosed gifts).
     7	This module turns that into the model's 13 ``allocation_share`` centers.
     8	
     9	Disclosed gifts: each gift's dollars are split equally across its
    10	organization's listed focus areas (tags are org-level, not per-gift); vehicle
    11	tags (``PASSTHROUGH``: funds, regrantors) are dropped when the organization
    12	lists substantive areas; generic health-delivery areas (``SPLIT_HEALTH``)
    13	split 50/50 between ``health_coverage`` and ``health_chc``.
    14	
    15	Undisclosed gifts are imputed rather than ignored. Scott's essays give each
    16	year's *total* (``meta.giving_tranches`` in parameters.yaml), so the
    17	undisclosed residual per year window is a known dollar amount; it is
    18	distributed across that window's undisclosed gifts in proportion to each
    19	recipient's **pre-gift IRS 990 total revenue** raised to an elasticity
    20	calibrated on the disclosed pairs (log-log OLS of gift size on revenue).
    21	Pre-gift means the latest ``tax_prd_yr`` strictly before the gift year — a
    22	Scott gift inflates receipt-year revenue, so same-year revenue would be
    23	endogenous. Recipients with no matched 990 (mostly non-US organizations) get
    24	the window's median weight. Years 2019-2021 form one window because the
    25	database attributes more disclosed 2021 dollars than the 2021 announcement
    26	total — year attribution is noisy at the boundary.
    27	
    28	Everything is deterministic from committed files
    29	(``data/yieldgiving/{organisations.json, area_map.json,
    30	leaf_to_archetype.yaml, propublica_revenue.jsonl}`` and
    31	``data/parameters.yaml``); ``tests/test_allocation.py`` asserts that
    32	``parameters.yaml`` carries exactly the derived shares.
