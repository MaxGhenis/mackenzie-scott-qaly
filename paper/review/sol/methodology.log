   206	# Dirichlet concentration governing uncertainty in the dollar allocation
   207	# across archetypes. AI-proposed, author-reviewed (higher = shares held closer
   208	# to central):
   209	# the share centers below are data-derived, but the undisclosed third of
   210	# dollars enters via a revenue-scaled imputation and the area->archetype
   211	# mapping embeds judgment.
   212	# ---------------------------------------------------------------------------
   213	allocation_concentration: 60
