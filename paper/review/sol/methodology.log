   155	# ---------------------------------------------------------------------------
   156	# TWO ORTHOGONAL ADJUSTMENTS (GiveWell-style), kept deliberately separate:
   157	#
   158	#   causal_credibility (per archetype, below) — IS THE MEASURED EFFECT REAL?
   159	#     Internal validity only: how well the study design identifies causation.
   160	#   realization_factor (global, here) — DOES SCOTT'S DOLLAR DELIVER IT?
   161	#     Everything between a real effect and her marginal grant: external
   162	#     validity/transport to her grantees, overhead leakage, counterfactual
   163	#     funging — net of the capacity benefits of large unrestricted gifts.
   164	#
   165	# Division of labor: transportability concerns live HERE, not in credibility;
   166	# cost-per-QALY priors are conditional on the effect being real and delivered.
   167	# Each doubt enters exactly one layer.
   168	#
   169	# LIMITATIONS (disclosed, not hidden): credibility is drawn independently per
   170	# archetype, while realization is one global draw — two opposite correlation
   171	# extremes. A tier-correlated credibility variant widens the 90% interval ~7%
   172	# and leaves the median unchanged. Credibility is also strictly positive, so
   173	# the model puts no mass on zero or harmful effects; for assumption-tier
   174	# buckets the mean of 0.07 approximates, but never reaches, a null.
   175	# ---------------------------------------------------------------------------
   176	realization_factor:
   177	  dist: triangular
   178	  low: 0.55
   179	  mode: 0.80
   180	  high: 1.10
   181	  unit: multiplier
   182	  source: >-
   183	    AI-PROPOSED, AUTHOR-REVIEWED PRIOR (no literature estimate exists for this quantity).
   184	    Downweight for transport/overhead/funging; upweight allowed past 1.0
   185	    because [Center for Effective Philanthropy (2023)](https://cep.org/wp-content/uploads/2023/11/BigGiftsStudy_Report_Y2_FNL.pdf)
   186	    finds large unrestricted gifts materially expand recipient capacity/reach.
   187	    Stress-test with the interactive's realization slider (it moves the MODE of
   188	    this triangle within [0.55, 1.10]).
   189	
   190	# Evidence tiers by causal-identification design. AI-PROPOSED, AUTHOR-REVIEWED
   191	# PRIORS (Claude drafted the levels):
   192	# `mean` is the central credibility weight (1 = take the estimate at face
   193	# value; 0 = shrink fully to the null of no health effect); `concentration`
   194	# sets the spread (lower = more uncertain). Weaker designs get a lower mean
   195	# AND a wider distribution. No published calibration of design -> credibility
   196	# exists; the ordering is the defensible part, the levels are judgment.
   197	evidence_tiers:
   198	  randomized:     {mean: 0.85, concentration: 22, design: "RCT / clean natural randomization (e.g., lottery)"}
   199	  strong_quasi:   {mean: 0.65, concentration: 13, design: "Credible quasi-experiment (DD/IV) with admin data and checks"}
   200	  moderate_quasi: {mean: 0.45, concentration: 8,  design: "Quasi-experiment with notable concerns or a contested literature"}
   201	  observational:  {mean: 0.22, concentration: 6,  design: "Associational; confounding-prone"}
   202	  projection:     {mean: 0.15, concentration: 6,  design: "Model/IAM projection; no direct causal estimate for this lever"}
   203	  assumption:     {mean: 0.07, concentration: 9,  design: "No causal health evidence; skeptical expert prior"}
   204	
