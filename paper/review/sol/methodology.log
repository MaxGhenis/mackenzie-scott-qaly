   285	        f"disclosed (${stats['disclosed_usd'] / 1e9:.2f}B) + "
   286	        f"${stats['imputed_usd'] / 1e9:.2f}B imputed over {stats['n_undisclosed']} gifts"
   287	    )
   288	    print(
   289	        f"gift~revenue elasticity {stats['elasticity']:.3f} "
   290	        f"(R^2 {stats['elasticity_r2']:.2f}, n={stats['n_calibration']}); "
   291	        f"{stats['n_revenue_fallback']} gifts on median-weight fallback"
   292	    )
   293	    print(f"{'archetype':30s} {'imputed':>8s} {'disclosed-only':>15s}")
   294	    for key, share in shares.items():
