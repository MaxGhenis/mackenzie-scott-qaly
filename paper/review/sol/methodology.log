    82	def load_revenue(data_dir: str | Path | None = None) -> dict[str, dict[int, float]]:
    83	    """org name -> {990 tax year -> total revenue} for matched organizations.
    84	
    85	    ``match_audit.jsonl``, when present, overlays the raw fetch: an LLM audit
