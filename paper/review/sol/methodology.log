   242	            residual = max(window_total[window] - disclosed_by_window[window], 0.0)
   243	            weights = [r**beta if r else None for _, _, r in rows]
   244	            known = [w for w in weights if w is not None]
   245	            fallback = median(known) if known else 1.0
