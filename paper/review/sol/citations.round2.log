link-text">Technology</span> 									</a> 															</dd> 					</div> 										<div class="c-meta__row c-meta__row--initiatives"> 						<dt class="c-meta__label"> 							Initiative						</dt>  						<dd class="c-meta__values"> 																<a class="c-meta__link" 										href="https://cega.berkeley.edu/collection/cost-transparency-initiative/" 																													> 										<span class="c-meta__link-text">Cost-Effectiveness Lab</span> 									</a> 															</dd> 					</div> 							</dl> 	</section> 	        </section> 		</main> <footer class="c-footer">     <div class="c-footer__container">         <div class="c-footer__inner">             <div class="c-footer__logo"> 				 <svg 	class="o-svg o-svg--logo c-footer__logo-svg"> 	<use class="o-svg__use" 	     xlink:href="https://cega.berkeley.edu/wp-content/themes/cega/assets/img/symbol/svg/sprite.symbol.svg?v=1.8#logo"/> </svg>             </div> 			<div class="c-footer__menu"><ul id="menu-footer-menu" class="c-footer__nav"><li><a href="https://cega.berkeley.edu/our-careers/"><span>Careers</span></a></li></li> <li><a href="https://cega.berkeley.edu/contact/"><span>Contact</span></a></li></li> <li><a href="http://go.cega.org/newsletter"><span>Newsletter</span></a></li></li> <li><a href="https://cega.berkeley.edu/support-us/"><span>Support CEGA</span></a></li></li> </ul></div>            <div class="c-footer__secondary-menu"> 				<nav class="c-footer__other-links"><a href="https://cega.berkeley.edu/cookie-policy/">Cookie Policy</a><a href="https://cega.berkeley.edu/accessibility-statement/">Accessibility Statement</a></nav>            </div>              <div class="c-footer__address">                 <strong>Address</strong> 				                    <span class="c-footer__address-text"> 					207 Giannini Hall, Berkeley, CA 94720					</span> 				            </div>         </div>     </div> </footer>     <div class="c-footer__placeholder js-footer-placeholder"></div>      <div class="c-parallax-